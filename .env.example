# Başkent Yaşam - Environment Variables Template
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
#
# Local development:
#   cp .env.example .env
#   docker compose up --build
#
# Production:
#   cp .env.example .env  (production değerleriyle doldurun)
#   docker compose -f docker-compose.prod.yml up --build -d

# ===================
# Runtime
# ===================
# Development | Production
ASPNETCORE_ENVIRONMENT=Development

# ===================
# Database
# ===================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme-use-strong-password-min-16-chars
POSTGRES_DB=oys3

# ===================
# JWT Authentication
# ===================
# Generate: openssl rand -base64 32  (en az 32 karakter)
JWT_SECRET_KEY=generate-a-secure-key-at-least-32-chars
# Development: 1440 (24h) önerilir. Production: 120-240 önerilir.
JWT_EXPIRES_MINUTES=1440

# ===================
# SuperAdmin (Production ilk kurulum)
# ===================
# Production'da demo seed hesapları oluşturulmaz; SuperAdmin env ile eklenir.
# Şifre en az 12 karakter olmalıdır.
SUPERADMIN_EMAIL=admin@yourdomain.com
SUPERADMIN_PASSWORD=change-me-strong-password
SUPERADMIN_NAME=Sistem Yöneticisi

# ===================
# SMTP (Email)
# ===================
# Gmail App Password: https://myaccount.google.com/apppasswords
# Kodda veya repoda gerçek şifre tutmayın.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME=Başkent Yaşam Platformu

# ===================
# URLs
# ===================
# Local development
FRONTEND_URL=http://localhost:3000
API_BASE_URL=http://localhost:5283

# Production örneği:
# FRONTEND_URL=https://yourdomain.com
# API_BASE_URL=https://yourdomain.com

# ===================
# Device Integration (Kamera modülü vb.)
# ===================
# Kütüphane doluluk push endpoint'i için cihaz token'ı
# Üretmek için: openssl rand -hex 20
DEVICE_TOKEN=generate-with-openssl-rand-hex-20

# ===================
# Optional Settings
# ===================
# Docker/reverse proxy arkasında true kalabilir; edge TLS kullanıyorsanız ayarlayın
DISABLE_HTTPS_REDIRECTION=true
